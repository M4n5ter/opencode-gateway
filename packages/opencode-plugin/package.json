{
  "name": "opencode-gateway",
  "version": "0.8.2",
  "description": "Gateway plugin for OpenCode",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opencode-gateway": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "generated/wasm/pkg",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:launcher": "node ./scripts/build-launcher.mjs",
    "build:launcher:all": "node ./scripts/build-launcher.mjs --all",
    "build:wasm": "node ../../scripts/build-binding.mjs",
    "check": "tsc --noEmit --project tsconfig.json && bun test src && node ./scripts/build.mjs && node ./scripts/smoke-node-import.mjs && bun ./scripts/smoke-bun-import.mjs",
    "prepack": "npm run build:wasm && npm run build",
    "test": "bun test src"
  },
  "keywords": [
    "opencode",
    "plugin",
    "gateway",
    "telegram",
    "automation"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M4n5ter/opencode-gateway.git",
    "directory": "packages/opencode-plugin"
  },
  "bugs": {
    "url": "https://github.com/M4n5ter/opencode-gateway/issues"
  },
  "homepage": "https://github.com/M4n5ter/opencode-gateway",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.6.4",
    "@opencode-ai/plugin": "^1.14.24",
    "@opencode-ai/sdk": "^1.14.24",
    "better-sqlite3": "^12.9.0",
    "fast-glob": "^3.3.3",
    "marked": "^18.0.2",
    "mime-types": "^3.0.2",
    "smol-toml": "^1.6.1",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "bun-types": "^1.3.13"
  }
}
